# Copy to .env và điền giá trị.
# Dùng cho: Oracle Cloud (docker-compose.oracle.yml) hoặc Neon (docker-compose.dev-neon.yml).

# Database - chọn một trong hai cách:
# Cách 1: Dùng Postgres bên ngoài (Neon, Supabase, ...) - chỉ cần POSTGRES_DSN
POSTGRES_DSN=postgresql://user:password@host/dbname?sslmode=require

# Cách 2: Dùng postgres trong docker-compose (Oracle / docker-compose.dev.yml)
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=doi_mat_khau_manh_o_day
POSTGRES_DB=ecommerce

# App
APP_ENV=production
HTTP_PORT=8080
JWT_SECRET=chuoi_bi_mat_ngau_nhien_dai_32_ky_tu_tro_len
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORD=

# Stripe (nếu dùng thanh toán)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=USD
STRIPE_SUCCESS_URL_BASE=https://your-frontend.com/checkout/success
STRIPE_CANCEL_URL_BASE=https://your-frontend.com/checkout/cancel

# OAuth Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=https://your-api-domain.com/api/v1/oauth/google/callback

# OAuth Facebook
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_REDIRECT_URL=https://your-api-domain.com/api/v1/oauth/facebook/callback

# Redis (để trống nếu không dùng)
REDIS_ADDR=
REDIS_PASSWORD=
